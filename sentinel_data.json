// 1. INJETANDO SEU JSON COMO BASE DE DADOS NACIONAL
const DATABASE = [
  {
    "ticket": "VALE3",
    "gatilhos": "Minério China / Infraestrutura",
    "hist_24h": "[01/04] Minério subiu 1.2% em Dalian; Estímulos civis confirmados.",
    "perf_12m": "-14.20%",
    "semaforo": "ENTRA",
    "trava": "-50%",
    "api_key": "BBA9X8Q14OFJIBRZ"
  },
  // ... (incluir os outros 9 ativos que você mandou)
];

// 2. FUNÇÃO DE RENDERIZAÇÃO BLINDADA
function renderSentinel() {
    const container = document.getElementById('app');
    container.innerHTML = ''; // Limpa para atualizar

    DATABASE.forEach(item => {
        // Busca preço em tempo real se existir no cache, senão deixa carregando
        const cache = JSON.parse(localStorage.getItem(item.ticket)) || {p: '---', c: '0.00'};
        
        // Define a cor baseada no seu semáforo
        const cor = item.semaforo === "ENTRA" ? "#00ff41" : (item.semaforo === "PULA" ? "#f9d71c" : "#ff3131");

        container.innerHTML += `
            <div class="card" style="border-left: 4px solid ${cor}">
                <div class="flex-header">
                    <b>${item.ticket}</b>
                    <span class="badge" style="background:${cor}15; color:${cor}">${item.semaforo}</span>
                </div>
                <div class="price">R$ ${cache.p} <small>(${cache.c}%)</small></div>
                <div class="intel">${item.hist_24h}</div>
                <div class="metrics">
                    <span>12M: ${item.perf_12m}</span> | <span>TRAVA: ${item.trava}</span>
                </div>
            </div>
        `;
    });
}

// 3. INJEÇÃO DE SINCRONIA (10 EM 10 MINUTOS)
async function syncB3() {
    for (let asset of DATABASE) {
        try {
            const res = await fetch(`https://www.alphavantage.co/query?function=GLOBAL_QUOTE&symbol=${asset.ticket}.SAO&apikey=${asset.api_key}`);
            const data = await res.json();
            if (data["Global Quote"]) {
                const quote = data["Global Quote"];
                localStorage.setItem(asset.ticket, JSON.stringify({
                    p: parseFloat(quote["05. price"]).toFixed(2),
                    c: parseFloat(quote["10. change percent"]).toFixed(2)
                }));
                renderSentinel(); // Atualiza a tela assim que o dado chega
            }
            await new Promise(r => setTimeout(r, 20000)); // Delay para respeitar a API
        } catch (e) { console.log("Erro ao injetar dado real em " + asset.ticket); }
   
        }
}
